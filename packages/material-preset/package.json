{
  "name": "@rhombuskit/material-preset",
  "version": "0.1.0",
  "license": "MIT",
  "sideEffects": ["*.css", "*.scss"],
  "publishConfig": { "access": "public" },
  "peerDependencies": {
    "@angular/material": "^21.0.0"
  },
  "dependencies": {
    "@rhombuskit/tokens": "workspace:*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./scss": {
      "sass": "./dist/scss/index.scss"
    },
    "./scss/*": {
      "sass": "./dist/scss/_*.scss"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "scripts": {
    "build": "tsup && node ../../tools/copy-material-preset-assets.mjs"
  }
}
