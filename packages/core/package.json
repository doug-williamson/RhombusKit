{
  "name": "@rhombuskit/core",
  "version": "1.3.0",
  "license": "MIT",
  "description": "Themeable, accessible Angular 21 component library — standalone, signal-based components over Angular Material, styled through the RhombusKit token contract.",
  "keywords": [
    "angular",
    "angular-material",
    "components",
    "ui",
    "design-system",
    "accessibility",
    "wcag",
    "standalone",
    "signals",
    "rhombuskit"
  ],
  "sideEffects": [
    "*.css",
    "*.scss"
  ],
  "publishConfig": {
    "access": "public",
    "directory": "../../dist/packages/core"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doug-williamson/RhombusKit.git",
    "directory": "packages/core"
  },
  "homepage": "https://rhombuskit.online",
  "bugs": {
    "url": "https://github.com/doug-williamson/RhombusKit/issues"
  },
  "peerDependencies": {
    "@angular/core": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/cdk": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/material": "^21.0.0",
    "@angular/router": "^21.0.0",
    "rxjs": "^7.8.0",
    "highlight.js": "^11.0.0"
  },
  "peerDependenciesMeta": {
    "highlight.js": {
      "optional": true
    }
  },
  "dependencies": {
    "@rhombuskit/tokens": "workspace:*",
    "@rhombuskit/theme-engine": "workspace:*"
  },
  "exports": {
    "./scss": {
      "sass": "./scss/index.scss"
    },
    "./scss/*": {
      "sass": "./scss/_*.scss"
    }
  }
}
