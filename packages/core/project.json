{
  "name": "core",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/core/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run core:ng-packagr",
          "node tools/copy-core-assets.mjs",
          "tsc -p packages/core/tsconfig.schematics.json",
          "node tools/copy-schematics-assets.mjs"
        ],
        "parallel": false,
        "env": {
          "NX_BUILDABLE_LIBRARIES_TASK_GRAPH": "true"
        }
      },
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "outputs": ["{workspaceRoot}/dist/packages/core"]
    },
    "ng-packagr": {
      "executor": "@nx/angular:package",
      "options": {
        "project": "packages/core/ng-package.json",
        "tsConfig": "packages/core/tsconfig.lib.json"
      },
      "dependsOn": ["^build"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/core/src/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "packages/core/jest.config.ts",
        "tsConfig": "packages/core/tsconfig.spec.json"
      }
    }
  }
}
