{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": false,
  "draft": false,
  "prerelease": false,
  "include-component-in-tag": false,
  "include-v-in-tag": true,
  "separate-pull-requests": false,
  "group-pull-request-title-pattern": "chore: release ${version}",
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "rhombuskit",
      "components": ["tokens", "theme-engine", "material-preset", "core"]
    },
    {
      "type": "node-workspace",
      "updatePeerDependencies": true
    }
  ],
  "packages": {
    "packages/tokens": {
      "package-name": "@rhombuskit/tokens",
      "component": "tokens",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/theme-engine": {
      "package-name": "@rhombuskit/theme-engine",
      "component": "theme-engine",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/material-preset": {
      "package-name": "@rhombuskit/material-preset",
      "component": "material-preset",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/core": {
      "package-name": "@rhombuskit/core",
      "component": "core",
      "changelog-path": "CHANGELOG.md"
    }
  }
}
